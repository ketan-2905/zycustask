# ──────────────────────────────────────────────────────────────────────────────
# Zycus Support AI — Environment Configuration
# Copy this file to .env and fill in the values you need.
# All variables have safe defaults — the system works without editing anything.
# ──────────────────────────────────────────────────────────────────────────────


# ── Application ───────────────────────────────────────────────────────────────

# Runtime environment. Used for logging and behaviour differences.
# Options: development | staging | production
APP_ENV=development


# ── Data paths ────────────────────────────────────────────────────────────────

# Directory containing accounts.json and tickets.json.
# If these files are absent, data-check reports missing and account-brief
# raises AccountDataUnavailable — no data is fabricated.
DATA_DIR=data

# Directory containing knowledge-base markdown articles (.md files).
# If absent or empty, KB retrieval returns no matches and known_issue_match
# is null. Triage still works — confidence is capped at 0.70 without KB.
KB_DIR=knowledge-base

# Directory where eval reports are written.
REPORTS_DIR=reports


# ── LLM provider (optional — disabled by default) ─────────────────────────────
#
# Default is "none" — fully deterministic, no API key required.
# Triage and account brief work completely without an LLM.
#
# Set to "openai" or "groq" to enable LLM-enhanced responses.
# PII is redacted from all payloads before they leave the process.
#
# Options: none | openai | groq
LLM_PROVIDER=none

# Model to use when LLM_PROVIDER is set.
# openai examples : gpt-4o-mini  |  gpt-4o  |  gpt-4-turbo
# groq examples   : llama-3.3-70b-versatile  |  llama-3.1-8b-instant  |  qwen/qwen3-32b
LLM_MODEL=

# Temperature for LLM calls. Keep at 0 for deterministic output.
LLM_TEMPERATURE=0

# Seed for reproducibility (OpenAI supports this; Groq ignores it gracefully).
LLM_SEED=42


# ── API keys ──────────────────────────────────────────────────────────────────
# Only needed when LLM_PROVIDER is set to the matching provider.
# Never commit real keys — this file is for documentation only.

# Required when LLM_PROVIDER=openai
OPENAI_API_KEY=

# Required when LLM_PROVIDER=groq
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=
